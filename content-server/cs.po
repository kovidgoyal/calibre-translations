msgstr "Indexování této knihovny bylo povoleno. V závislosti na velikosti knihovny může indexování všech knih trvat dlouho."

#: /__w/calibre/calibre/src/pyj/book_list/fts.pyj:73
#: /__w/calibre/calibre/src/pyj/book_list/fts.pyj:288
msgid "Full text searching disabled"
