msgid "Searching, please wait"
msgstr "Vyhledává se, čekejte"

#: /__w/calibre/calibre/src/pyj/book_list/fts.pyj:179
msgid "Re-index all books in this library"
msgstr "Přeindexovat všechny knihy v této knihovně"

#: /__w/calibre/calibre/src/pyj/book_list/fts.pyj:181
msgid "Disable full text search"
msgstr "Zakázat fulltextové vyhledávání"

#: /__w/calibre/calibre/src/pyj/book_list/fts.pyj:184
