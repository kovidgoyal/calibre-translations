#: /__w/calibre/calibre/src/pyj/book_list/search.pyj:631
msgid "Category partitioning method"
msgstr "Método de partición de categorías"

#: /__w/calibre/calibre/src/pyj/book_list/search.pyj:632
msgid "First Letter"
msgstr "primera letra"

#: /__w/calibre/calibre/src/pyj/book_list/search.pyj:632
msgid "Disable"
msgstr "inhabilitar"

