msgstr "Linux：修复 Fedora 系统下 calibre 7 网络请求失败的问题"

#: Changelog.yaml:0
msgid "23 Nov, 2023"
msgstr "23 Nov, 2023"

#: Changelog.yaml:0
msgid ""
